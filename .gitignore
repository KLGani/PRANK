# Dependencies (Never commit these, they are downloaded via npm install)
node_modules/
jspm_packages/
web_modules/

# Production Build Outputs (Generated automatically during deployment)
dist/
build/
out/

# Environment Variables & Secrets (CRITICAL: Never leak your API keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Logs (Generated when crashes or errors occur)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor/OS specific files (Local settings unique to your computer)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db